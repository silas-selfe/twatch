# environment & caches
.venv/
__pycache__/
*.pyc
.DS_Store

# model weights (auto-downloaded by watch.py on first run)
yolo11s.pt
*.pt

# event snapshots: 3+ GB of images, privacy-sensitive -- stays local
snapshots/

# sqlite sidecars (transient; traffic.db itself IS committed)
*.db-wal
*.db-shm

# per-deployment files -- never committed
site.yaml
.env
tracker_runtime.yaml
.tmptest/

# central-infra ops runbook -- kept local, not part of the open-source node project
deploy/WEB_DEPLOY.md

# discover.py outputs -- contain camera credentials & preview frames, keep local
node/discovered/
node/cameras/
node/compose.cameras.yaml
